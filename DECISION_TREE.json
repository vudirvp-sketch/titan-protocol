{
  "version": "5.1.0",
  "description": "TITAN FUSE Protocol State Machine",
  "initial_state": "INIT",
  "states": {
    "INIT": {
      "description": "Initial state - entry point classification",
      "transitions": [
        {
          "event": "REPO_URL",
          "target": "BOOTSTRAP",
          "condition": "input matches github.com/{user}/{repo}"
        },
        {
          "event": "FILE_PATH",
          "target": "PHASE_0",
          "condition": "input is direct file path"
        },
        {
          "event": "REPOMIX",
          "target": "PHASE_0",
          "condition": "input is repomix file"
        },
        {
          "event": "REPO_HOST",
          "target": "BOOTSTRAP",
          "condition": "SKILL.md or PROTOCOL.md in current directory"
        }
      ]
    },
    "BOOTSTRAP": {
      "description": "TIER -1 Bootstrap phase - repository navigation",
      "transitions": [
        {
          "event": "GATE_REPO_01_PASS",
          "target": "PHASE_0",
          "condition": "bootstrap sequence complete, INPUT_QUEUE non-empty"
        },
        {
          "event": "NO_INPUTS",
          "target": "ABORTED",
          "condition": "inputs/ empty"
        }
      ]
    },
    "PHASE_0": {
      "description": "Initialization & Indexing",
      "transitions": [
        {
          "event": "GATE_00_PASS",
          "target": "PHASE_1",
          "condition": "NAV_MAP exists, all chunks indexed"
        },
        {
          "event": "GATE_00_FAIL",
          "target": "ABORTED",
          "condition": "cannot build NAV_MAP"
        }
      ]
    },
    "PHASE_1": {
      "description": "Search & Discovery",
      "transitions": [
        {
          "event": "GATE_01_PASS",
          "target": "PHASE_2",
          "condition": "all target patterns scanned"
        }
      ]
    },
    "PHASE_2": {
      "description": "Analysis & Classification",
      "transitions": [
        {
          "event": "GATE_02_PASS",
          "target": "PHASE_3",
          "condition": "all issues classified with ISSUE_ID"
        }
      ]
    },
    "PHASE_3": {
      "description": "Planning",
      "transitions": [
        {
          "event": "GATE_03_PASS",
          "target": "EXECUTION_GATE_CHECK",
          "condition": "plan validated, no KEEP_VETO violations"
        },
        {
          "event": "KEEP_VETO",
          "target": "ABORTED",
          "condition": "attempt to modify protected content"
        },
        {
          "event": "CYCLE_DETECTED",
          "target": "ROLLBACK",
          "condition": "CycleDetector found circular dependency"
        }
      ]
    },
    "EXECUTION_GATE_CHECK": {
      "description": "INVAR-05 execution gate validation - code execution safety check",
      "transitions": [
        {
          "event": "GATE_PASS",
          "target": "PHASE_4",
          "condition": "execution gate validation passed"
        },
        {
          "event": "GATE_FAIL",
          "target": "ABORTED",
          "condition": "execution gate validation failed"
        }
      ]
    },
    "PHASE_4": {
      "description": "Execution & Validation",
      "transitions": [
        {
          "event": "GATE_04_PASS",
          "target": "MULTI_AGENT_DISPATCH",
          "condition": "validation pass, gaps within threshold"
        },
        {
          "event": "GATE_04_WARN",
          "target": "MULTI_AGENT_DISPATCH",
          "condition": "gaps within warning threshold, human ack"
        },
        {
          "event": "GATE_04_BLOCK",
          "target": "ROLLBACK",
          "condition": "SEV-1/SEV-2 gaps exceed threshold"
        },
        {
          "event": "VALIDATION_FAIL",
          "target": "PHASE_4",
          "condition": "retry after patch"
        }
      ]
    },
    "MULTI_AGENT_DISPATCH": {
      "description": "TIER_7 multi-agent task distribution",
      "transitions": [
        {
          "event": "DISPATCH_SUCCESS",
          "target": "AGENT_SYNC",
          "condition": "tasks dispatched to all agents"
        },
        {
          "event": "DISPATCH_FAIL",
          "target": "ROLLBACK",
          "condition": "agent dispatch failed"
        }
      ]
    },
    "AGENT_SYNC": {
      "description": "TIER_7 agent synchronization checkpoint",
      "transitions": [
        {
          "event": "SYNC_COMPLETE",
          "target": "PHASE_5",
          "condition": "all agents synchronized"
        },
        {
          "event": "SYNC_TIMEOUT",
          "target": "MULTI_AGENT_DISPATCH",
          "condition": "agent sync timeout, retry dispatch"
        }
      ]
    },
    "PHASE_5": {
      "description": "Delivery & Hygiene",
      "transitions": [
        {
          "event": "GATE_05_PASS",
          "target": "COMPLETE",
          "condition": "artifacts generated, hygiene complete"
        },
        {
          "event": "GATE_05_FAIL",
          "target": "ABORTED",
          "condition": "cannot generate required artifacts"
        }
      ]
    },
    "ROLLBACK": {
      "description": "Recovery state",
      "transitions": [
        {
          "event": "RETRY",
          "target": "PHASE_4",
          "condition": "rollback complete, ready to retry"
        },
        {
          "event": "ABORT",
          "target": "ABORTED",
          "condition": "max retries exceeded"
        }
      ]
    },
    "COMPLETE": {
      "description": "Session completed successfully",
      "transitions": []
    },
    "ABORTED": {
      "description": "Session aborted",
      "transitions": []
    }
  },
  "terminal_states": ["COMPLETE", "ABORTED"],
  "gate_sequence": [
    "GATE-REPO-00",
    "GATE-REPO-01",
    "GATE-00",
    "GATE-01",
    "GATE-02",
    "GATE-03",
    "GATE-PLAN",
    "GATE-AMENDMENT",
    "GATE-04",
    "GATE-05"
  ],
  "version_history": [
    {
      "version": "3.2.1",
      "date": "2026-04-07",
      "notes": "Previous stable version"
    },
    {
      "version": "5.1.0",
      "date": "2026-04-10",
      "notes": "TIER_7 integration: MULTI_AGENT_DISPATCH, AGENT_SYNC, EXECUTION_GATE_CHECK states; CycleDetector integration; GATE-PLAN, GATE-AMENDMENT gates"
    }
  ]
}
