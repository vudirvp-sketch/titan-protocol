{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "titan://schemas/validator.schema.json",
  "title": "TITAN Validator Schema",
  "description": "MVP validation schema for 8 primitive types used in TITAN Protocol v5.0.0",
  "version": "1.2.0",
  "definitions": {
    "string_type": {
      "type": "object",
      "properties": {
        "type": { "const": "string" },
        "minLength": { "type": "integer", "minimum": 0 },
        "maxLength": { "type": "integer", "minimum": 1 },
        "pattern": { "type": "string", "description": "Regex pattern for validation" },
        "enum": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "Allowed values for enumeration"
        },
        "default": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["type"],
      "additionalProperties": false
    },
    "integer_type": {
      "type": "object",
      "properties": {
        "type": { "const": "integer" },
        "minimum": { "type": "integer" },
        "maximum": { "type": "integer" },
        "exclusiveMinimum": { "type": "integer" },
        "exclusiveMaximum": { "type": "integer" },
        "multipleOf": { "type": "integer", "minimum": 1 },
        "default": { "type": "integer" },
        "description": { "type": "string" }
      },
      "required": ["type"],
      "additionalProperties": false
    },
    "number_type": {
      "type": "object",
      "properties": {
        "type": { "const": "number" },
        "minimum": { "type": "number" },
        "maximum": { "type": "number" },
        "exclusiveMinimum": { "type": "boolean", "default": false },
        "exclusiveMaximum": { "type": "boolean", "default": false },
        "default": { "type": "number" },
        "description": { "type": "string" }
      },
      "required": ["type"],
      "additionalProperties": false
    },
    "boolean_type": {
      "type": "object",
      "properties": {
        "type": { "const": "boolean" },
        "default": { "type": "boolean" },
        "description": { "type": "string" }
      },
      "required": ["type"],
      "additionalProperties": false
    },
    "enum_type": {
      "type": "object",
      "properties": {
        "type": { "const": "enum" },
        "values": { 
          "type": "array", 
          "minItems": 1,
          "description": "Allowed values for enumeration"
        },
        "default": { "description": "Default value (must be one of the values)" },
        "description": { "type": "string" }
      },
      "required": ["type", "values"],
      "additionalProperties": false
    },
    "array_type": {
      "type": "object",
      "properties": {
        "type": { "const": "array" },
        "items": { 
          "description": "Schema for array items",
          "$ref": "#"
        },
        "minItems": { "type": "integer", "minimum": 0 },
        "maxItems": { "type": "integer", "minimum": 0 },
        "uniqueItems": { "type": "boolean", "default": false },
        "default": { "type": "array" },
        "description": { "type": "string" }
      },
      "required": ["type", "items"],
      "additionalProperties": false
    },
    "object_type": {
      "type": "object",
      "properties": {
        "type": { "const": "object" },
        "properties": { 
          "type": "object",
          "description": "Property definitions"
        },
        "required": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of required property names"
        },
        "additionalProperties": { 
          "type": "boolean",
          "default": true,
          "description": "Whether additional properties are allowed"
        },
        "default": { "type": "object" },
        "description": { "type": "string" }
      },
      "required": ["type"],
      "additionalProperties": false
    },
    "object_ref_type": {
      "type": "object",
      "properties": {
        "type": { "const": "object_ref" },
        "ref_path": { 
          "type": "string", 
          "pattern": "^[a-zA-Z0-9_/.-]+$",
          "description": "Path to referenced schema file"
        },
        "schema_validation": { 
          "type": "boolean", 
          "default": true,
          "description": "Whether to validate against referenced schema"
        },
        "description": { "type": "string" }
      },
      "required": ["type", "ref_path"],
      "additionalProperties": false
    }
  },
  "oneOf": [
    { "$ref": "#/definitions/string_type" },
    { "$ref": "#/definitions/integer_type" },
    { "$ref": "#/definitions/number_type" },
    { "$ref": "#/definitions/boolean_type" },
    { "$ref": "#/definitions/enum_type" },
    { "$ref": "#/definitions/array_type" },
    { "$ref": "#/definitions/object_type" },
    { "$ref": "#/definitions/object_ref_type" }
  ]
}
