{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/vudirvp-sketch/titan-protocol/schemas/context_graph.schema.json",
  "title": "TITAN Context Graph Schema",
  "description": "Schema for TITAN Protocol Context Graph - a trust-aware graph of context nodes and their relationships",
  "type": "object",
  "required": ["version", "nodes", "edges", "metadata"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Schema version",
      "default": "1.0.0"
    },
    "session_id": {
      "type": "string",
      "description": "Optional session identifier"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ContextNode"
      },
      "description": "List of context nodes"
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ContextEdge"
      },
      "description": "List of relationships between nodes"
    },
    "metadata": {
      "$ref": "#/definitions/GraphMetadata",
      "description": "Graph metadata and statistics"
    }
  },
  "definitions": {
    "NodeType": {
      "type": "string",
      "enum": ["file", "symbol", "module", "config", "checkpoint", "artifact"],
      "description": "Type of context node"
    },
    "EdgeRelation": {
      "type": "string",
      "enum": ["imports", "calls", "depends_on", "extends", "implements", "references", "contains", "produces"],
      "description": "Type of relationship between nodes"
    },
    "TrustTier": {
      "type": "string",
      "enum": ["TIER_1_TRUSTED", "TIER_2_RELIABLE", "TIER_3_UNCERTAIN", "TIER_4_UNTRUSTED"],
      "description": "Trust tier classification"
    },
    "VersionVector": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      },
      "description": "Vector clock for change tracking"
    },
    "ContextNode": {
      "type": "object",
      "required": ["id", "type", "location", "trust_score"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique node identifier (usually file path)"
        },
        "type": {
          "$ref": "#/definitions/NodeType"
        },
        "location": {
          "type": "string",
          "description": "File path or location of the node"
        },
        "trust_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.5,
          "description": "Trust score from 0.0 to 1.0"
        },
        "last_modified": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of last modification"
        },
        "content_hash": {
          "type": "string",
          "description": "SHA-256 hash of file content"
        },
        "semantic_hash": {
          "type": "string",
          "description": "Semantic hash ignoring comments/whitespace"
        },
        "version_vector": {
          "$ref": "#/definitions/VersionVector",
          "description": "Version vector for change tracking"
        },
        "usage_count": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Number of times node was accessed"
        },
        "success_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 1.0,
          "description": "Success rate of operations on this node"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true,
          "description": "Additional node metadata"
        }
      }
    },
    "ContextEdge": {
      "type": "object",
      "required": ["from", "to", "relation"],
      "properties": {
        "from": {
          "type": "string",
          "description": "Source node ID"
        },
        "to": {
          "type": "string",
          "description": "Target node ID"
        },
        "relation": {
          "$ref": "#/definitions/EdgeRelation"
        },
        "weight": {
          "type": "number",
          "minimum": 0,
          "default": 1.0,
          "description": "Edge weight/strength"
        },
        "line_number": {
          "type": "integer",
          "minimum": 1,
          "description": "Line number where relationship is defined"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true,
          "description": "Additional edge metadata"
        }
      }
    },
    "GraphMetadata": {
      "type": "object",
      "required": ["generated_at", "total_nodes", "total_edges"],
      "properties": {
        "generated_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of graph generation"
        },
        "total_nodes": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of nodes"
        },
        "total_edges": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of edges"
        },
        "avg_trust_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Average trust score across all nodes"
        },
        "stale_nodes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of stale node IDs"
        },
        "trust_distribution": {
          "type": "object",
          "properties": {
            "TIER_1_TRUSTED": {
              "type": "integer",
              "minimum": 0
            },
            "TIER_2_RELIABLE": {
              "type": "integer",
              "minimum": 0
            },
            "TIER_3_UNCERTAIN": {
              "type": "integer",
              "minimum": 0
            },
            "TIER_4_UNTRUSTED": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "protocol_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "TITAN Protocol version"
        },
        "root_path": {
          "type": "string",
          "description": "Root path used for graph generation"
        }
      }
    }
  }
}
