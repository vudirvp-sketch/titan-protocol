{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TITAN FUSE Protocol Configuration Schema",
  "description": "Configuration schema for TITAN FUSE Protocol v3.3.0",
  "type": "object",
  "properties": {
    "session": {
      "type": "object",
      "properties": {
        "id": {"type": ["string", "null"]},
        "max_tokens": {"type": "integer", "minimum": 1000},
        "max_time_minutes": {"type": "integer", "minimum": 1},
        "checkpoint_enabled": {"type": "boolean"}
      }
    },
    "chunking": {
      "type": "object",
      "properties": {
        "default_size": {"type": "integer", "minimum": 100},
        "large_file_size": {"type": "integer"},
        "min_size": {"type": "integer"},
        "semantic_boundaries": {"type": "boolean"},
        "boundary_markers": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "chunking_limits": {
      "type": "object",
      "properties": {
        "max_chars_per_chunk": {"type": "integer"},
        "max_tokens_per_chunk": {"type": "integer"},
        "enforce_secondary_limits": {"type": "boolean"}
      }
    },
    "llm_query": {
      "type": "object",
      "properties": {
        "max_response_tokens": {"type": "integer"},
        "max_chunk_tokens": {"type": "integer"},
        "fallback_enabled": {"type": "boolean"},
        "fallback": {
          "type": "object",
          "properties": {
            "max_attempts": {"type": "integer"},
            "size_reduction_factor": {"type": "number"},
            "timeout_seconds": {"type": "integer"},
            "model_fallback": {"type": "boolean"},
            "models": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "max_patch_iterations": {"type": "integer"},
        "parallel_safe_check": {"type": "boolean"},
        "gate_04": {
          "type": "object",
          "properties": {
            "max_sev1_gaps": {"type": "integer"},
            "max_sev2_gaps": {"type": "integer"},
            "max_total_gap_pct": {"type": "integer"}
          }
        }
      }
    },
    "checkpoint": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "format_version": {"type": "string"},
        "chunk_checksums": {"type": "boolean"},
        "partial_resumption": {"type": "boolean"},
        "max_age_days": {"type": "integer"},
        "path": {"type": "string"},
        "interval_tokens": {"type": "integer"},
        "interval_seconds": {"type": "integer"},
        "compression": {"type": "string", "enum": ["none", "gzip", "zstd"]},
        "security": {"type": "string"},
        "serialization": {"type": "string", "enum": ["json_zstd", "json", "pickle_unsafe"]},
        "encryption": {"type": "string"},
        "encryption_key_path": {"type": "string"},
        "namespace_isolation": {"type": "boolean"},
        "namespace": {"type": "string"},
        "auto_cleanup": {"type": "boolean"},
        "cleanup_interval_days": {"type": "integer"}
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "directory": {"type": "string"},
        "clean_mode": {"type": "boolean"},
        "full_merge": {"type": "boolean"},
        "full_merge_max_lines": {"type": "integer"},
        "artifacts": {
          "type": "object",
          "properties": {
            "index": {"type": "boolean"},
            "symbol_map": {"type": "boolean"},
            "change_log": {"type": "boolean"},
            "decision_record": {"type": "boolean"},
            "metrics": {"type": "boolean"}
          }
        }
      }
    },
    "multi_file": {
      "type": "object",
      "properties": {
        "default_limit": {"type": "integer"},
        "hard_limit": {"type": "integer"},
        "require_approval": {"type": "boolean"},
        "dependency_resolution": {"type": "boolean"},
        "max_dependency_depth": {"type": "integer"},
        "cross_file_patches": {"type": "boolean"}
      }
    },
    "approval": {
      "type": "object",
      "properties": {
        "mode": {"type": "string", "enum": ["interactive", "callback", "auto-reject"]},
        "release_locks_on_wait": {"type": "boolean"},
        "lock_ttl_seconds": {"type": "integer"},
        "force_resume_allowed": {"type": "boolean"},
        "callback": {
          "type": "object",
          "properties": {
            "url": {"type": ["string", "null"]},
            "timeout": {"type": "integer"},
            "retries": {"type": "integer"}
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "output_file": {"type": "string"},
        "prometheus": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean"},
            "port": {"type": "integer"}
          }
        },
        "webhook": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean"},
            "url": {"type": ["string", "null"]},
            "events": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        }
      }
    },
    "validators": {
      "type": "object",
      "properties": {
        "auto_load": {"type": "boolean"},
        "timeout": {"type": "integer"},
        "disabled": {
          "type": "array",
          "items": {"type": "string"}
        },
        "sandbox_enabled": {"type": "boolean"},
        "sandbox_type": {"type": "string", "enum": ["wasm", "gvisor", "subprocess", "none"]},
        "sandbox_config": {
          "type": "object",
          "properties": {
            "memory_limit_mb": {"type": "integer"},
            "timeout_ms": {"type": "integer"},
            "max_output_size": {"type": "integer"}
          }
        }
      }
    },
    "mode": {
      "type": "object",
      "properties": {
        "current": {"type": "string", "enum": ["direct", "auto", "manual", "interactive"]},
        "presets_dir": {"type": "string"}
      }
    },
    "model_routing": {
      "type": "object",
      "properties": {
        "root_model": {"type": "string"},
        "leaf_model": {"type": "string"},
        "track_costs": {"type": "boolean"},
        "log_model_usage": {"type": "boolean"},
        "validation": {
          "type": "object",
          "properties": {
            "require_root_model": {"type": "boolean"},
            "require_leaf_model": {"type": "boolean"},
            "warn_on_empty": {"type": "boolean"}
          }
        }
      }
    },
    "model_fallback": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "chain": {
          "type": "array",
          "items": {"type": "string"}
        },
        "triggers": {
          "type": "object",
          "properties": {
            "timeout_ms": {"type": "integer"},
            "error_rate_threshold": {"type": "number"}
          }
        },
        "degradation_mode": {"type": "string"}
      }
    },
    "model_downgrade_allowed": {"type": "boolean"},
    "budget": {
      "type": "object",
      "properties": {
        "sev_allocation": {
          "type": "object",
          "properties": {
            "sev_1_ratio": {"type": "number", "minimum": 0, "maximum": 1},
            "sev_2_ratio": {"type": "number", "minimum": 0, "maximum": 1},
            "sev_3_4_ratio": {"type": "number", "minimum": 0, "maximum": 1}
          }
        },
        "actions": {
          "type": "object",
          "properties": {
            "WARNING": {
              "type": "array",
              "items": {"type": "string"}
            },
            "EXCEEDED": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        }
      }
    },
    "sandbox": {
      "type": "object",
      "properties": {
        "timeout_ms": {"type": "integer", "minimum": 100},
        "memory_limit_mb": {"type": "integer", "minimum": 16}
      }
    },
    "confidence": {
      "type": "object",
      "properties": {
        "enable_advisory": {"type": "boolean"},
        "early_exit_threshold": {"type": "string"},
        "require_acknowledgement": {"type": "boolean"},
        "log_confidence": {"type": "boolean"}
      }
    },
    "recursion": {
      "type": "object",
      "properties": {
        "max_recursion_depth": {"type": "integer", "minimum": 1},
        "track_peak": {"type": "boolean"}
      }
    },
    "telemetry": {
      "type": "object",
      "properties": {
        "enable_token_tracking": {"type": "boolean"},
        "calculate_percentiles": {"type": "boolean"},
        "track_latency": {"type": "boolean"},
        "include_model_breakdown": {"type": "boolean"}
      }
    },
    "security": {
      "type": "object",
      "properties": {
        "execution_mode": {"type": "string", "enum": ["trusted", "sandbox", "human_gate", "disabled"]},
        "sandbox_type": {"type": "string", "enum": ["none", "docker", "venv", "restricted_subprocess"]},
        "permitted_operations": {
          "type": "array",
          "items": {"type": "string"}
        },
        "blocked_operations": {
          "type": "array",
          "items": {"type": "string"}
        },
        "max_input_file_size_mb": {"type": "integer"},
        "max_total_input_size_mb": {"type": "integer"},
        "secrets_scan": {"type": "boolean"},
        "secrets_baseline": {"type": "string"},
        "fail_on_detection": {"type": "boolean"},
        "workspace_path": {"type": ["string", "null"]},
        "redos_timeout_ms": {"type": "integer"}
      }
    },
    "development": {
      "type": "object",
      "properties": {
        "debug": {"type": "boolean"},
        "keep_intermediates": {"type": "boolean"},
        "dry_run": {"type": "boolean"},
        "verbose": {"type": "boolean"}
      }
    },
    "logging": {
      "type": "object",
      "properties": {
        "level": {"type": "string", "enum": ["debug", "info", "warning", "error"]},
        "file": {"type": ["string", "null"]},
        "timestamps": {"type": "boolean"},
        "include_session_id": {"type": "boolean"}
      }
    },
    "repository": {
      "type": "object",
      "properties": {
        "directories": {
          "type": "array",
          "items": {"type": "string"}
        },
        "required_files": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "secrets": {
      "type": "object",
      "properties": {
        "backend": {"type": "string", "enum": ["keyring", "vault", "env"]},
        "prefix": {"type": "string"}
      }
    },
    "audit": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "signing_key_path": {"type": "string"},
        "trail_path": {"type": "string"},
        "sign_critical_events": {"type": "boolean"}
      }
    },
    "policy": {
      "type": "object",
      "properties": {
        "max_recursion_depth": {"type": "integer"}
      }
    },
    "intent_classifier": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "method": {"type": "string"},
        "confidence_threshold": {"type": "number"},
        "log_all": {"type": "boolean"}
      }
    },
    "anomaly_detection": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "baseline_sessions": {"type": "integer"},
        "threshold_multiplier": {"type": "number"},
        "action": {"type": "string"}
      }
    },
    "event_journal": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "path": {"type": "string"},
        "max_size_mb": {"type": "integer"}
      }
    },
    "locks": {
      "type": "object",
      "properties": {
        "backend": {"type": "string", "enum": ["file", "redis", "etcd"]},
        "lock_dir": {"type": "string"},
        "redis": {
          "type": "object",
          "properties": {
            "host": {"type": "string"},
            "port": {"type": "integer"},
            "db": {"type": "integer"},
            "password": {"type": ["string", "null"]},
            "key_prefix": {"type": "string"}
          }
        },
        "etcd": {
          "type": "object",
          "properties": {
            "host": {"type": "string"},
            "port": {"type": "integer"},
            "key_prefix": {"type": "string"}
          }
        }
      }
    },
    "gate04": {
      "type": "object",
      "properties": {
        "confidence_override": {"type": "boolean"},
        "max_sev2_gaps": {"type": "integer"},
        "allow_advisory_pass": {"type": "boolean"}
      }
    },
    "gate_sensitivity": {
      "type": "object",
      "properties": {
        "deterministic": {
          "type": "object",
          "properties": {
            "fail_on_any_gap": {"type": "boolean"},
            "warn_threshold_pct": {"type": "integer"},
            "max_sev1_gaps": {"type": "integer"},
            "max_sev2_gaps": {"type": "integer"},
            "max_sev3_gaps": {"type": "integer"},
            "max_sev4_gaps": {"type": "integer"},
            "allow_advisory_pass": {"type": "boolean"},
            "allow_unsafe": {"type": "boolean"},
            "confidence_override": {"type": "boolean"}
          }
        },
        "guided_autonomy": {
          "type": "object",
          "properties": {
            "fail_on_any_gap": {"type": "boolean"},
            "warn_threshold_pct": {"type": "integer"},
            "max_sev1_gaps": {"type": "integer"},
            "max_sev2_gaps": {"type": "integer"},
            "max_sev3_gaps": {"type": "integer"},
            "max_sev4_gaps": {"type": "integer"},
            "allow_advisory_pass": {"type": "boolean"},
            "allow_unsafe": {"type": "boolean"},
            "confidence_override": {"type": "boolean"}
          }
        },
        "fast_prototype": {
          "type": "object",
          "properties": {
            "fail_on_any_gap": {"type": "boolean"},
            "warn_threshold_pct": {"type": "integer"},
            "max_sev1_gaps": {"type": "integer"},
            "max_sev2_gaps": {"type": "integer"},
            "max_sev3_gaps": {"type": "integer"},
            "max_sev4_gaps": {"type": "integer"},
            "allow_advisory_pass": {"type": "boolean"},
            "allow_unsafe": {"type": "boolean"},
            "confidence_override": {"type": "boolean"}
          }
        }
      }
    },
    "pre_intent": {
      "type": "object",
      "properties": {
        "token_limit": {"type": "integer"},
        "fallback_mode": {"type": "string"},
        "ambiguity_threshold": {"type": "number"}
      }
    },
    "storage": {
      "type": "object",
      "properties": {
        "backend": {"type": "string", "enum": ["local", "s3", "gcs"]},
        "namespace": {"type": "string"},
        "local": {
          "type": "object",
          "properties": {
            "base_path": {"type": "string"},
            "create_dirs": {"type": "boolean"}
          }
        },
        "s3": {
          "type": "object",
          "properties": {
            "bucket": {"type": ["string", "null"]},
            "prefix": {"type": "string"},
            "region": {"type": "string"},
            "credentials": {
              "type": "object",
              "properties": {
                "access_key": {"type": ["string", "null"]},
                "secret_key": {"type": ["string", "null"]},
                "session_token": {"type": ["string", "null"]}
              }
            },
            "endpoint_url": {"type": ["string", "null"]}
          }
        },
        "gcs": {
          "type": "object",
          "properties": {
            "bucket": {"type": ["string", "null"]},
            "prefix": {"type": "string"},
            "project": {"type": ["string", "null"]},
            "credentials_path": {"type": ["string", "null"]}
          }
        }
      }
    }
  }
}
