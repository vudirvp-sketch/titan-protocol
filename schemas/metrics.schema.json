{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TITAN FUSE Metrics Schema",
  "description": "Schema for metrics.json output",
  "type": "object",
  "properties": {
    "session": {
      "type": "object",
      "properties": {
        "id": {"type": "string"},
        "duration_seconds": {"type": "integer"},
        "status": {"type": "string", "enum": ["COMPLETE", "PARTIAL", "ABORTED"]}
      },
      "required": ["id", "status"]
    },
    "processing": {
      "type": "object",
      "properties": {
        "chunks_total": {"type": "integer"},
        "issues_found": {"type": "integer"},
        "issues_fixed": {"type": "integer"},
        "gaps": {"type": "integer"}
      }
    },
    "gates": {
      "type": "object",
      "properties": {
        "GATE-00": {"type": "string", "enum": ["PASS", "FAIL", "WARN", "PENDING"]},
        "GATE-01": {"type": "string", "enum": ["PASS", "FAIL", "WARN", "PENDING"]},
        "GATE-02": {"type": "string", "enum": ["PASS", "FAIL", "WARN", "PENDING"]},
        "GATE-03": {"type": "string", "enum": ["PASS", "FAIL", "WARN", "PENDING"]},
        "GATE-04": {"type": "string", "enum": ["PASS", "FAIL", "WARN", "PENDING"]},
        "GATE-05": {"type": "string", "enum": ["PASS", "FAIL", "WARN", "PENDING"]}
      }
    },
    "tokens": {
      "type": "object",
      "properties": {
        "total": {"type": "integer"},
        "root_model": {"type": "integer"},
        "leaf_model": {"type": "integer"},
        "per_query_p50": {"type": "integer"},
        "per_query_p95": {"type": "integer"}
      }
    },
    "token_attribution": {
      "type": "object",
      "description": "ITEM-MODEL-002: Token usage per gate for cost attribution",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "prompt_tokens": {"type": "integer", "description": "Total prompt tokens used by this gate"},
          "completion_tokens": {"type": "integer", "description": "Total completion tokens used by this gate"},
          "total_tokens": {"type": "integer", "description": "Total tokens (prompt + completion)"},
          "call_count": {"type": "integer", "description": "Number of times this gate was invoked"},
          "avg_tokens_per_call": {"type": "number", "description": "Average tokens per call"},
          "total_duration_ms": {"type": "number", "description": "Total duration in milliseconds"},
          "avg_duration_ms": {"type": "number", "description": "Average duration per call in milliseconds"},
          "first_started_at": {"type": ["string", "null"], "description": "ISO timestamp of first gate start"},
          "last_started_at": {"type": ["string", "null"], "description": "ISO timestamp of most recent gate start"},
          "last_ended_at": {"type": ["string", "null"], "description": "ISO timestamp of most recent gate end"}
        },
        "required": ["prompt_tokens", "completion_tokens", "total_tokens", "call_count"]
      }
    },
    "token_attribution_summary": {
      "type": "object",
      "description": "ITEM-MODEL-002: Summary statistics for token attribution",
      "properties": {
        "total_tokens": {"type": "integer", "description": "Total tokens across all gates"},
        "total_prompt_tokens": {"type": "integer", "description": "Total prompt tokens across all gates"},
        "total_completion_tokens": {"type": "integer", "description": "Total completion tokens across all gates"},
        "gate_count": {"type": "integer", "description": "Number of unique gates tracked"},
        "total_calls": {"type": "integer", "description": "Total number of gate invocations"}
      },
      "required": ["total_tokens", "gate_count", "total_calls"]
    },
    "assessment": {
      "type": "object",
      "properties": {
        "signal": {"type": "string", "enum": ["WEAK", "MODERATE", "STRONG"]},
        "readiness": {"type": "string", "enum": ["PRODUCTION_READY", "EXPERIMENTAL", "REVIEW_REQUIRED"]},
        "combined_score": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "model_routing": {
      "type": "object",
      "properties": {
        "root_calls": {"type": "integer"},
        "leaf_calls": {"type": "integer"},
        "fallback_calls": {"type": "integer"},
        "fallback_rate": {"type": "number"}
      }
    },
    "diagnostics": {
      "type": "object",
      "properties": {
        "total_failures": {"type": "integer"},
        "unique_symptoms": {"type": "integer"},
        "escalations": {"type": "integer"}
      }
    }
  },
  "required": ["session"]
}
