{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TITAN FUSE Metrics Output",
  "description": "Structured metrics for monitoring and dashboards - v3.4.0",
  "type": "object",
  "properties": {
    "session": {
      "type": "object",
      "description": "Session metadata",
      "properties": {
        "id": {
          "type": "string",
          "description": "Session UUID"
        },
        "start_time": {
          "type": "string",
          "format": "date-time"
        },
        "end_time": {
          "type": "string",
          "format": "date-time"
        },
        "duration_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "status": {
          "type": "string",
          "enum": ["COMPLETE", "PARTIAL", "FAILED", "IN_PROGRESS"]
        }
      },
      "required": ["id", "start_time", "end_time", "duration_seconds", "status"]
    },
    "source": {
      "type": "object",
      "description": "Source file information",
      "properties": {
        "file": {
          "type": "string",
          "description": "Source file name"
        },
        "lines": {
          "type": "integer",
          "minimum": 0
        },
        "chunks": {
          "type": "integer",
          "minimum": 0
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "checksum": {
          "type": "string"
        }
      },
      "required": ["file", "lines", "chunks"]
    },
    "processing": {
      "type": "object",
      "description": "Processing statistics",
      "properties": {
        "issues_found": {
          "type": "integer",
          "minimum": 0
        },
        "issues_fixed": {
          "type": "integer",
          "minimum": 0
        },
        "issues_deferred": {
          "type": "integer",
          "minimum": 0
        },
        "issues_skipped": {
          "type": "integer",
          "minimum": 0
        },
        "gaps": {
          "type": "integer",
          "minimum": 0
        },
        "gap_severity": {
          "type": "object",
          "properties": {
            "SEV-1": { "type": "integer", "minimum": 0 },
            "SEV-2": { "type": "integer", "minimum": 0 },
            "SEV-3": { "type": "integer", "minimum": 0 },
            "SEV-4": { "type": "integer", "minimum": 0 }
          }
        },
        "chunks_processed": {
          "type": "integer",
          "minimum": 0
        },
        "chunks_failed": {
          "type": "integer",
          "minimum": 0
        },
        "batches_completed": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": ["issues_found", "issues_fixed", "gaps", "chunks_processed"]
    },
    "budget": {
      "type": "object",
      "description": "Token budget tracking",
      "properties": {
        "tokens_used": {
          "type": "integer",
          "minimum": 0
        },
        "tokens_max": {
          "type": "integer",
          "minimum": 0
        },
        "utilization_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "llm_query_calls": {
          "type": "integer",
          "minimum": 0
        },
        "avg_chunk_tokens": {
          "type": "number",
          "minimum": 0
        }
      },
      "required": ["tokens_used", "tokens_max", "utilization_pct"]
    },
    "llm_telemetry": {
      "type": "object",
      "description": "v3.4.0 LLM query telemetry metrics",
      "properties": {
        "per_query_p50": {
          "type": "number",
          "description": "P50 latency per query in milliseconds",
          "minimum": 0
        },
        "per_query_p95": {
          "type": "number",
          "description": "P95 latency per query in milliseconds",
          "minimum": 0
        },
        "per_query_p99": {
          "type": "number",
          "description": "P99 latency per query in milliseconds",
          "minimum": 0
        },
        "total_latency_ms": {
          "type": "integer",
          "description": "Total cumulative latency in milliseconds",
          "minimum": 0
        },
        "model_used": {
          "type": "string",
          "description": "Primary LLM model identifier used for queries"
        },
        "model_breakdown": {
          "type": "object",
          "description": "Token usage by model",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "calls": { "type": "integer" },
              "tokens": { "type": "integer" },
              "avg_latency_ms": { "type": "number" }
            }
          }
        },
        "fallback_used": {
          "type": "boolean",
          "description": "Whether fallback model was used"
        },
        "fallback_count": {
          "type": "integer",
          "description": "Number of fallback invocations",
          "minimum": 0
        }
      }
    },
    "gates": {
      "type": "object",
      "description": "Verification gate status",
      "properties": {
        "GATE-00": { "type": "string", "enum": ["PASS", "FAIL", "WARN", "SKIP"] },
        "GATE-01": { "type": "string", "enum": ["PASS", "FAIL", "WARN", "SKIP"] },
        "GATE-02": { "type": "string", "enum": ["PASS", "FAIL", "WARN", "SKIP"] },
        "GATE-03": { "type": "string", "enum": ["PASS", "FAIL", "WARN", "SKIP"] },
        "GATE-PLAN": { "type": "string", "enum": ["PASS", "FAIL", "WARN", "SKIP"] },
        "GATE-AMENDMENT": { "type": "string", "enum": ["PASS", "FAIL", "WARN", "SKIP"] },
        "GATE-04": { "type": "string", "enum": ["PASS", "FAIL", "WARN", "SKIP"] },
        "GATE-05": { "type": "string", "enum": ["PASS", "FAIL", "WARN", "SKIP"] },
        "GATE-REPO-00": { "type": "string", "enum": ["PASS", "FAIL", "WARN", "SKIP"] },
        "GATE-REPO-01": { "type": "string", "enum": ["PASS", "FAIL", "WARN", "SKIP"] },
        "GATE-REPO-02": { "type": "string", "enum": ["PASS", "FAIL", "WARN", "SKIP"] }
      }
    },
    "quality": {
      "type": "object",
      "description": "Quality metrics",
      "properties": {
        "confidence_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "zero_drift_violations": {
          "type": "integer",
          "minimum": 0
        },
        "keep_preserved": {
          "type": "boolean"
        },
        "idempotency_verified": {
          "type": "boolean"
        }
      },
      "required": ["confidence_score", "zero_drift_violations", "keep_preserved"]
    },
    "artifacts": {
      "type": "object",
      "description": "Generated artifact paths",
      "properties": {
        "index": { "type": "string" },
        "symbol_map": { "type": "string" },
        "change_log": { "type": "string" },
        "decision_record": { "type": "string" },
        "merged_output": { "type": "string" }
      }
    },
    "multi_agent": {
      "type": "object",
      "description": "TIER_7 multi-agent metrics",
      "properties": {
        "agents_dispatched": {
          "type": "integer",
          "minimum": 0
        },
        "agents_completed": {
          "type": "integer",
          "minimum": 0
        },
        "sync_latency_ms": {
          "type": "integer",
          "minimum": 0
        },
        "conflict_resolutions": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "errors": {
      "type": "array",
      "description": "Error log",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string", "format": "date-time" },
          "phase": { "type": "string" },
          "chunk": { "type": "string" },
          "message": { "type": "string" },
          "severity": { "type": "string" }
        }
      }
    }
  },
  "required": ["session", "source", "processing", "budget", "gates", "quality"]
}
