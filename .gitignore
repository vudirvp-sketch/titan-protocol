# Agent working directories
/tmp/titan_ws_*/
*.checkpoint.json.tmp

# Intermediate artifacts (keep final only)
WORK_DIR/
working_copy/

# Debug and draft outputs
*.debug.md
*_draft.md
*_iter*.md

# OS artifacts
.DS_Store
Thumbs.db

# Node modules (if using JS validators)
node_modules/

# Python cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Environment
.env
.env.local

# Generated outputs (keep .gitkeep for directory structure)
outputs/*.md
outputs/*.json
outputs/*.yaml

# Runtime secrets (NEVER commit)
.titan/hmac_secret
.titan/hmac_fallback_secret
.titan/audit_trail.json

# Session state
sessions/current.json

# Checkpoints (runtime)
checkpoints/checkpoint.json
checkpoints/checkpoint.context.md