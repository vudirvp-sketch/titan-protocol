{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TITAN FUSE Checkpoint Format v2.0",
  "description": "Enhanced checkpoint format with chunk-level recovery support",
  "type": "object",
  "required": [
    "session_id",
    "protocol_version",
    "source_file",
    "source_checksum",
    "gates_passed",
    "completed_batches",
    "timestamp",
    "resumable",
    "resumption_type"
  ],
  "properties": {
    "session_id": {
      "type": "string",
      "description": "Unique session identifier (UUID)",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "protocol_version": {
      "type": "string",
      "description": "Protocol version used for this session",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"
    },
    "source_file": {
      "type": "string",
      "description": "Path to the source file being processed"
    },
    "source_checksum": {
      "type": "string",
      "description": "SHA-256 checksum of the source file",
      "pattern": "^[a-f0-9]{64}$"
    },
    "chunk_checksums": {
      "type": "object",
      "description": "SHA-256 checksums for each chunk (enables partial recovery)",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      }
    },
    "completed_chunks": {
      "type": "array",
      "description": "List of chunk IDs that have been fully processed",
      "items": {
        "type": "string",
        "pattern": "^C\\d+$"
      }
    },
    "pending_chunks": {
      "type": "array",
      "description": "List of chunk IDs still pending processing",
      "items": {
        "type": "string",
        "pattern": "^C\\d+$"
      }
    },
    "modification_map": {
      "type": "object",
      "description": "Track modifications per chunk for partial resumption",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "start": { "type": "integer", "minimum": 1 },
          "end": { "type": "integer", "minimum": 1 },
          "hash": { "type": "string" },
          "modifications": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "line": { "type": "integer" },
                "type": { "type": "string", "enum": ["add", "delete", "modify"] },
                "description": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "gates_passed": {
      "type": "array",
      "description": "List of verification gates that have been passed",
      "items": {
        "type": "string",
        "pattern": "^GATE(-REPO)?-\\d+$"
      }
    },
    "completed_batches": {
      "type": "array",
      "description": "List of batch IDs that have been completed",
      "items": {
        "type": "string",
        "pattern": "^BATCH_\\d+$"
      }
    },
    "open_issues": {
      "type": "array",
      "description": "List of open issue IDs",
      "items": {
        "type": "string"
      }
    },
    "chunk_cursor": {
      "type": "string",
      "description": "Current chunk being processed",
      "pattern": "^C\\d+$"
    },
    "timestamp": {
      "type": "string",
      "description": "ISO-8601 timestamp of last checkpoint update",
      "format": "date-time"
    },
    "resumable": {
      "type": "boolean",
      "description": "Whether this checkpoint can be resumed"
    },
    "resumption_type": {
      "type": "string",
      "description": "Type of resumption possible",
      "enum": ["FULL", "PARTIAL", "FRESH"]
    },
    "budget_used": {
      "type": "integer",
      "description": "Tokens used so far in this session",
      "minimum": 0
    },
    "budget_max": {
      "type": "integer",
      "description": "Maximum tokens allowed for this session",
      "minimum": 0
    },
    "source_line_count": {
      "type": "integer",
      "description": "Total lines in source file",
      "minimum": 0
    },
    "chunk_count": {
      "type": "integer",
      "description": "Total number of chunks",
      "minimum": 0
    },
    "issues_found": {
      "type": "integer",
      "description": "Total issues found during processing",
      "minimum": 0
    },
    "issues_fixed": {
      "type": "integer",
      "description": "Issues that have been fixed",
      "minimum": 0
    },
    "gaps": {
      "type": "array",
      "description": "List of gap markers in the output",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "chunk": { "type": "string" },
          "severity": { "type": "string", "enum": ["SEV-1", "SEV-2", "SEV-3", "SEV-4"] },
          "description": { "type": "string" }
        }
      }
    },
    "state_snapshot": {
      "type": "object",
      "description": "Current state snapshot from QUICK_ORIENT header",
      "properties": {
        "current_task": { "type": "string" },
        "last_completed_batch": { "type": "string" },
        "next_action": { "type": "string" },
        "blocked_by": { "type": "string" },
        "active_issues": { "type": "array", "items": { "type": "string" } },
        "context_mode": { "type": "string", "enum": ["REPL", "DIRECT"] }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata",
      "additionalProperties": true
    }
  }
}
