{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TITAN FUSE Checkpoint Schema",
  "description": "Schema for TITAN FUSE Protocol session checkpoints",
  "type": "object",
  "required": [
    "session_id",
    "protocol_version",
    "source_file",
    "source_checksum",
    "gates_passed",
    "completed_batches",
    "timestamp"
  ],
  "properties": {
    "session_id": {
      "type": "string",
      "description": "Unique session identifier (UUID)",
      "format": "uuid"
    },
    "protocol_version": {
      "type": "string",
      "description": "Protocol version used",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"
    },
    "source_file": {
      "type": "string",
      "description": "Path to the source file being processed"
    },
    "source_checksum": {
      "type": "string",
      "description": "SHA-256 checksum of the source file"
    },
    "gates_passed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "GATE-REPO-00",
          "GATE-REPO-01",
          "GATE-REPO-02",
          "GATE-00",
          "GATE-01",
          "GATE-02",
          "GATE-03",
          "GATE-04",
          "GATE-05"
        ]
      },
      "description": "List of verification gates passed"
    },
    "completed_batches": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of completed batch IDs"
    },
    "open_issues": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of open issue IDs"
    },
    "chunk_cursor": {
      "type": "string",
      "description": "Current chunk being processed"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of checkpoint"
    },
    "recursion_depth": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "Current recursion depth"
    },
    "max_recursion_depth": {
      "type": "integer",
      "minimum": 1,
      "default": 1,
      "description": "Maximum allowed recursion depth"
    },
    "cursor_state": {
      "type": "object",
      "properties": {
        "current_file": {
          "type": "string"
        },
        "current_line": {
          "type": "integer",
          "minimum": 0
        },
        "current_chunk": {
          "type": "string"
        },
        "offset_delta": {
          "type": "integer"
        }
      }
    },
    "budget_used": {
      "type": "integer",
      "minimum": 0,
      "description": "Tokens used in session"
    },
    "budget_max": {
      "type": "integer",
      "minimum": 0,
      "description": "Maximum tokens allowed"
    },
    "state": {
      "type": "string",
      "enum": [
        "INIT",
        "BOOTSTRAP",
        "PHASE_0",
        "PHASE_1",
        "PHASE_2",
        "PHASE_3",
        "PHASE_4",
        "PHASE_5",
        "ROLLBACK",
        "COMPLETE",
        "ABORTED"
      ],
      "description": "Current state in the state machine"
    }
  }
}
