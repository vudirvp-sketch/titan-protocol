{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TITAN FUSE Checkpoint v3.2.1",
  "description": "Session persistence checkpoint for resumption with enhanced tracking",
  "type": "object",
  "required": ["session_id", "protocol_version", "source_file", "source_checksum", "gates_passed", "completed_batches", "open_issues", "chunk_cursor", "timestamp", "cursor_state"],
  "properties": {
    "session_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique session identifier"
    },
    "protocol_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Protocol version used (semver)"
    },
    "source_file": {
      "type": "string",
      "description": "Path to source file being processed"
    },
    "source_checksum": {
      "type": "string",
      "description": "SHA-256 checksum of source file"
    },
    "gates_passed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["GATE-00", "GATE-01", "GATE-02", "GATE-03", "GATE-04", "GATE-05", "GATE-REPO-00", "GATE-REPO-01", "GATE-REPO-02"]
      },
      "description": "List of verification gates passed"
    },
    "completed_batches": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of completed batch IDs"
    },
    "open_issues": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of open issue IDs"
    },
    "chunk_cursor": {
      "type": "string",
      "description": "Current chunk position"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp"
    },
    "cursor_state": {
      "type": "object",
      "description": "NEW in v3.2.1: Cursor tracking state",
      "required": ["current_file", "current_line", "current_chunk", "offset_delta"],
      "properties": {
        "current_file": {
          "type": "string",
          "description": "Currently processed file"
        },
        "current_line": {
          "type": "integer",
          "minimum": 0,
          "description": "Current line number in file"
        },
        "current_chunk": {
          "type": "string",
          "description": "Current chunk ID"
        },
        "current_section": {
          "type": "string",
          "description": "Current section name (optional)"
        },
        "offset_delta": {
          "type": "integer",
          "description": "Lines added/removed in session"
        }
      }
    },
    "chunk_checksums": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Per-chunk checksums for partial recovery"
    },
    "issue_dependency_graph": {
      "type": "object",
      "description": "NEW in v3.2.1: Issue dependency DAG",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blocks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "severity": {
            "type": "string",
            "enum": ["SEV-1", "SEV-2", "SEV-3", "SEV-4"]
          }
        }
      }
    },
    "file_inventory_path": {
      "type": "string",
      "description": "NEW in v3.2.1: Path to file_inventory.json"
    },
    "crossref_report": {
      "type": "object",
      "description": "NEW in v3.2.1: Cross-reference validation report",
      "properties": {
        "total_references": {
          "type": "integer"
        },
        "resolved": {
          "type": "integer"
        },
        "broken": {
          "type": "integer"
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["IN_PROGRESS", "COMPLETE", "ROLLBACK", "ABORTED", "READY"],
      "default": "IN_PROGRESS"
    }
  }
}
