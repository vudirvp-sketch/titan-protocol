# Agent Ignore File — TITAN FUSE Protocol
# Analog of .gitignore for LLM agents
# Files and patterns listed here should NOT be indexed or processed

# =============================================================================
# TEMPORARY WORKING FILES
# =============================================================================

# Agent working directories
/tmp/titan_ws_*/
*.checkpoint.json.tmp

# Intermediate artifacts (keep final only)
WORK_DIR/
working_copy/
*.working

# =============================================================================
# DEBUG AND DRAFT OUTPUTS
# =============================================================================

# Debug files
*.debug.md
*_debug.md
debug_*.log

# Draft outputs
*_draft.md
*_iter*.md
*.draft

# Temporary test outputs
test_output_*.md
tmp_*.md

# =============================================================================
# LOG FILES
# =============================================================================

logs/
*.log
debug_*.log
error_*.log

# =============================================================================
# CHECKPOINT TEMPORARY FILES
# =============================================================================

checkpoints/*.tmp
checkpoints/*.bak
checkpoints/*.old

# =============================================================================
# OS AND EDITOR ARTIFACTS
# =============================================================================

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*~

# Editor directories
.idea/
.vscode/
*.swp
*.swo
*.sublime-*

# =============================================================================
# BUILD AND CACHE
# =============================================================================

__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Node modules (if any scripts use npm)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# SENSITIVE FILES (NEVER PROCESS)
# =============================================================================

# Secrets and credentials
.env
.env.*
*.pem
*.key
secrets/
credentials/

# Private configurations
*.private.*
private/

# =============================================================================
# LARGE BINARY FILES
# =============================================================================

# Images (unless specifically needed)
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.ico
*.svg

# Documents
*.pdf
*.docx
*.xlsx
*.pptx

# Archives
*.zip
*.tar
*.gz
*.rar
*.7z

# =============================================================================
# EXAMPLE PATTERNS
# =============================================================================

# Example: ignore all .bak files
# *.bak

# Example: ignore specific directory
# examples/large/

# =============================================================================
# END OF AGENT IGNORE
# =============================================================================
